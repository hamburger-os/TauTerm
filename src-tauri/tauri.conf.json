{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/v2/crates/tauri-utils/schema.json",
  "productName": "TauTerm",
  "version": "0.4.0",
  "identifier": "com.tauterm.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run check-com0com && npm run build",
    "beforeDevCommand": "npm run dev",
    "beforeBundleCommand": "node scripts/set-admin-manifest.js"
  },
  "app": {
    "windows": [
      {
        "title": "TauTerm - Terminal Emulator",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; script-src 'self'"
    }
  },
  "bundle": {
    "icon": [
      "../src/assets/icons/logo.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/com0com/*": "./"
    },
    "linux": {
      "deb": {
        "depends": ["socat"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {}
}
