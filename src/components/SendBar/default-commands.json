{
  "version": 1,
  "name": "Linux 常用命令",
  "defaultDelay": 500,
  "commands": [
    { "id": "cmd-file-01", "command": "ls -la", "note": "列出目录文件（含隐藏文件）", "delay": 500 },
    { "id": "cmd-file-02", "command": "cd /", "note": "切换到根目录", "delay": 200 },
    { "id": "cmd-file-03", "command": "pwd", "note": "显示当前工作目录", "delay": 200 },
    { "id": "cmd-file-04", "command": "cat /etc/os-release", "note": "查看系统版本信息", "delay": 500 },
    { "id": "cmd-file-05", "command": "echo $PATH", "note": "显示环境变量 PATH", "delay": 200 },
    { "id": "cmd-file-06", "command": "touch /tmp/test.txt", "note": "创建空文件", "delay": 200 },
    { "id": "cmd-file-07", "command": "mkdir -p /tmp/testdir", "note": "递归创建目录", "delay": 200 },
    { "id": "cmd-file-08", "command": "rm -rf /tmp/testdir", "note": "强制删除目录", "delay": 200 },
    { "id": "cmd-file-09", "command": "cp -r /tmp/a /tmp/b", "note": "递归复制目录", "delay": 300 },
    { "id": "cmd-file-10", "command": "mv /tmp/a /tmp/b", "note": "移动/重命名文件", "delay": 200 },
    { "id": "cmd-file-11", "command": "chmod 755 /tmp/script.sh", "note": "修改文件权限", "delay": 200 },
    { "id": "cmd-file-12", "command": "chown root:root /tmp/file", "note": "修改文件所有者", "delay": 200 },
    { "id": "cmd-proc-01", "command": "ps aux", "note": "查看所有进程", "delay": 500 },
    { "id": "cmd-proc-02", "command": "top -n 1", "note": "查看进程资源占用（单次）", "delay": 1000 },
    { "id": "cmd-proc-03", "command": "kill -9 1", "note": "强制终止进程", "delay": 200 },
    { "id": "cmd-sys-01", "command": "df -h", "note": "查看磁盘使用情况", "delay": 500 },
    { "id": "cmd-sys-02", "command": "du -sh /tmp", "note": "查看目录占用空间", "delay": 500 },
    { "id": "cmd-sys-03", "command": "free -m", "note": "查看内存使用情况", "delay": 300 },
    { "id": "cmd-sys-04", "command": "uname -a", "note": "查看内核版本", "delay": 200 },
    { "id": "cmd-sys-05", "command": "dmesg | tail -20", "note": "查看内核日志最近 20 行", "delay": 500 },
    { "id": "cmd-sys-06", "command": "uptime", "note": "查看系统运行时间", "delay": 200 },
    { "id": "cmd-sys-07", "command": "lsusb", "note": "列出 USB 设备", "delay": 300 },
    { "id": "cmd-sys-08", "command": "lspci", "note": "列出 PCI 设备", "delay": 300 },
    { "id": "cmd-sys-09", "command": "lsmod", "note": "列出已加载内核模块", "delay": 500 },
    { "id": "cmd-sys-10", "command": "modprobe -l", "note": "列出可用内核模块", "delay": 300 },
    { "id": "cmd-net-01", "command": "ifconfig -a", "note": "查看网络接口信息", "delay": 500 },
    { "id": "cmd-net-02", "command": "ip addr show", "note": "查看 IP 地址（iproute2）", "delay": 300 },
    { "id": "cmd-net-03", "command": "ping -c 3 127.0.0.1", "note": "Ping 本地（3次）", "delay": 3000 },
    { "id": "cmd-net-04", "command": "netstat -tlnp", "note": "查看 TCP 监听端口", "delay": 500 },
    { "id": "cmd-net-05", "command": "ss -tlnp", "note": "查看 TCP 监听端口（ss）", "delay": 500 },
    { "id": "cmd-net-06", "command": "iptables -L -n", "note": "查看防火墙规则", "delay": 500 },
    { "id": "cmd-net-07", "command": "wget --version", "note": "检查 wget 版本", "delay": 300 },
    { "id": "cmd-net-08", "command": "curl --version", "note": "检查 curl 版本", "delay": 300 },
    { "id": "cmd-svc-01", "command": "systemctl list-units --type=service", "note": "列出 systemd 服务", "delay": 1000 },
    { "id": "cmd-svc-02", "command": "journalctl --no-pager -n 20", "note": "查看系统日志最近 20 行", "delay": 500 },
    { "id": "cmd-svc-03", "command": "mount", "note": "查看挂载信息", "delay": 300 },
    { "id": "cmd-txt-01", "command": "find /tmp -name '*.log'", "note": "查找日志文件", "delay": 500 },
    { "id": "cmd-txt-02", "command": "grep -r 'error' /var/log/", "note": "递归搜索包含 error 的日志", "delay": 1000 },
    { "id": "cmd-txt-03", "command": "tail -f /var/log/syslog", "note": "实时查看系统日志", "delay": 200 },
    { "id": "cmd-txt-04", "command": "head -20 /etc/passwd", "note": "查看文件前 20 行", "delay": 200 },
    { "id": "cmd-archive-01", "command": "tar -czf /tmp/test.tar.gz /tmp/testdir", "note": "压缩目录为 tar.gz", "delay": 500 },
    { "id": "cmd-archive-02", "command": "tar -xzf /tmp/test.tar.gz -C /tmp/out", "note": "解压 tar.gz 到指定目录", "delay": 500 },
    { "id": "cmd-archive-03", "command": "gzip -d /tmp/file.gz", "note": "解压 gzip 文件", "delay": 300 }
  ]
}
